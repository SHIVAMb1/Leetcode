class Solution {
    public int findNumbers(int[] nums) {
        int even=0;
        int odd=0;
        //int j=0;
       // int []arr=new int [nums.length];
        for(int i=0;i<nums.length;i++){
           // if(nums[i]>0){
                int j=nums[i];
                int d=0;
                while(j>0){
                    j=j/10;
                    d++;
                }
                if(d%2==0){
                    even++;
                }
        }
        return even;
    }
}
