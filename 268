import java.util.Arrays;

class Solution {
    public int missingNumber(int[] nums) {

        Arrays.sort(nums);
        int i=0;
        while(i<nums.length-1){
            if(nums[i]==nums[i+1]-1){
                i++;
            }
            else{
                return nums[i]+1;
            }
        }
        if(nums[0]==1){
            return 0;
        }
        return nums[i]+1;
    }
}
