class Solution {
    public int maxArea(int[] height) {
        int left=0;
        int right=height.length-1;
        int i=0;
        int area=0;
        int max=0;
        while(i<height.length){
            int width=right-left;
            if(height[left]>=height[right]){
                area=width*height[right];
                right--;
            }
            else if(height[left]<=height[right]){
                area=width*height[left];
                left++;
            }
            else{
                area=width*right;
            }
            if(area>max){
                max=area;
            }
            i++;
        }
        return max;
    }
}
